    {
      "name": "Rooms",
      "item": [
        {
          "name": "List Rooms",
          "request": { "method": "GET", "url": { "raw": "{{base_url}}/api/rooms", "host": ["{{base_url}}"], "path": ["api", "rooms"] } },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('200 OK', () => pm.response.to.have.status(200));"] } }]
        },
        {
          "name": "Get Room",
          "request": { "method": "GET", "url": { "raw": "{{base_url}}/api/rooms/{{room_id}}", "host": ["{{base_url}}"], "path": ["api", "rooms", "{{room_id}}"] } },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('200 OK', () => pm.response.to.have.status(200));"] } }]
        },
